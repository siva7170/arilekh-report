@page "/"
@page "/index.html"
@inject DesignerStateService State
@inject UndoRedoService UndoRedo
@inject ClipboardService Clipboard
@using ReportDesigner.Core
@using System.Net; 
@inject IJSRuntime JS
@inject NavigationManager NavManager
@implements IDisposable
@using ReportDesigner.Designer.Helpers

<div class="rd-designer" data-theme="@(State.IsDarkMode ? "dark" : "light")"
     @onmousemove="OnMouseMove" @onmouseup="OnMouseUp"
     @onkeydown="OnKeyDown" tabindex="0">

    <!-- ── Toolbar ─────────────────────────────────────────────────── -->
    <DesignerToolbar />

    <!-- ── Body: palette | canvas | properties ─────────────────────── -->
    <div class="rd-body">

        @if (State.Mode == DesignerMode.Design)
        {
            <!-- Left panel: tabbed (Fields / Sources / Explorer) -->
            <div class="rd-panel rd-panel--left">
                <LeftPanel OpenSchemaEditorCallback="() => _schemaEditor?.Open()" />
            </div>

            <!-- Centre: canvas -->
            <div class="rd-canvas-scroll" id="canvasScroll"
                 @onclick="OnCanvasBackgroundClick">
                <ReportCanvas />
            </div>

            <!-- Right panel: properties -->
            <div class="rd-panel rd-panel--right">
                <PropertiesPanel />
            </div>
        }
        else
        {
            <!-- Preview mode: full-width iframe -->
            <div class="rd-preview-host">
                <PreviewPanel />
            </div>
        }

    </div>

    <!-- ── Schema Editor Dialog ────────────────────────────────────── -->
    <SchemaEditorDialog @ref="_schemaEditor" />

    <!-- ── Global context menu (rendered at root level, never clipped) ── -->
    @if (State.ContextMenu.IsVisible)
    {
        <!-- Click-away backdrop -->
        <div style="position:fixed;inset:0;z-index:9998;"
             @onclick="State.HideContextMenu"
             @oncontextmenu:preventDefault="true"
             @oncontextmenu="State.HideContextMenu"></div>

        <div class="rd-context-menu"
             style="top:@(State.ContextMenu.Y)px;left:@(State.ContextMenu.X)px"
             @onclick:stopPropagation="true">

            @if (State.ContextMenu.IsFieldMenu)
            {
                <div class="rd-context-menu__item" @onclick="CtxCopy">📋 Copy</div>
                <div class="@($"rd-context-menu__item{(!Clipboard.HasContent ? " rd-context-menu__item--disabled" : "")}")"
                     @onclick="CtxPaste">
                    📌 Paste
                </div>
                <div class="rd-context-menu__item" @onclick="CtxDuplicate">⧉ Duplicate</div>
                <div class="rd-context-menu__sep"></div>
                <div class="rd-context-menu__item rd-context-menu__item--danger"
                     @onclick="CtxDelete">🗑 Delete</div>
            }
            else if (State.ContextMenu.IsSectionMenu)
            {
                <div class="@($"rd-context-menu__item{(!Clipboard.HasContent ? " rd-context-menu__item--disabled" : "")}")"
                     @onclick="CtxPasteIntoSection">
                    📌 Paste Field Here
                </div>
                <div class="rd-context-menu__sep"></div>
                <div class="rd-context-menu__item rd-context-menu__item--danger"
                     @onclick="CtxDeleteSection">🗑 Delete Section</div>
            }
        </div>
    }

</div>

