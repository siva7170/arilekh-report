@inherits LayoutComponentBase
@inject ReportDesigner.Designer.Services.DesignerStateService State
@implements IDisposable

<div class="rd-shell">
    @Body
</div>

<!-- Toast container -->
<div class="rd-toast-container">
    @foreach (var toast in _toasts)
    {
        <div class="rd-toast rd-toast--@toast.Type.ToString().ToLower()">
            @toast.Text
        </div>
    }
</div>

@code {
    private readonly List<ToastMessage> _toasts = [];

    protected override void OnInitialized()
        => State.OnToast += HandleToast;

    private async void HandleToast(ToastMessage msg)
    {
        _toasts.Add(msg);
        StateHasChanged();
        await Task.Delay(msg.DurationMs);
        _toasts.Remove(msg);
        StateHasChanged();
    }

    public void Dispose() => State.OnToast -= HandleToast;
}

@using ReportDesigner.Designer.Models
