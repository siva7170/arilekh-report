<Window x:Class="ReportDesigner.VsExtension.Wizard.DatasetSchemaWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dataset Schema Editor"
        Width="720" Height="540"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e2e"
        Foreground="#abb2bf">

    <Window.Resources>
        <!-- Dark button style -->
        <Style TargetType="Button" x:Key="DarkBtn">
            <Setter Property="Background"   Value="#313148"/>
            <Setter Property="Foreground"   Value="#abb2bf"/>
            <Setter Property="BorderBrush"  Value="#3d3d5c"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="10,4"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="FontSize"     Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3d3d5c"/>
                    <Setter Property="Foreground" Value="#e0e0f0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="PrimaryBtn" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Background"  Value="#5b8ef0"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#5b8ef0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7aa4f7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Button" x:Key="DangerBtn" BasedOn="{StaticResource DarkBtn}">
            <Setter Property="Foreground"  Value="#e06c75"/>
            <Setter Property="BorderBrush" Value="#e06c75"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"        Value="#13131f"/>
            <Setter Property="Foreground"        Value="#e0e0f0"/>
            <Setter Property="BorderBrush"       Value="#3d3d5c"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="Padding"           Value="4,2"/>
            <Setter Property="FontSize"          Value="12"/>
            <Setter Property="CaretBrush"        Value="#e0e0f0"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background"        Value="#13131f"/>
            <Setter Property="Foreground"        Value="#e0e0f0"/>
            <Setter Property="BorderBrush"       Value="#3d3d5c"/>
            <Setter Property="FontSize"          Value="12"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="#2a2a3e"/>
            <Setter Property="Foreground"   Value="#abb2bf"/>
            <Setter Property="BorderBrush"  Value="#3d3d5c"/>
            <Setter Property="Padding"      Value="6,4"/>
            <Setter Property="FontSize"     Value="11"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#e0e0f0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#313148"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2a2a3e"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Schema name row -->
            <RowDefinition Height="*"/>     <!-- Grid -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar row -->
            <RowDefinition Height="Auto"/>  <!-- Sample data section -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Dataset Schema Editor" FontSize="16" FontWeight="Bold"
                       Foreground="#e0e0f0"/>
            <TextBlock x:Name="FilePathLabel" FontSize="10" Foreground="#6b7280"
                       Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Schema name -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Dataset name:" VerticalAlignment="Center"
                       Foreground="#abb2bf" FontSize="12"/>
            <TextBox x:Name="SchemaNameBox" Grid.Column="1"
                     ToolTip="Name used in .rdx DataSource references"/>
            <TextBlock Grid.Column="2" FontSize="10" Foreground="#6b7280"
                       VerticalAlignment="Center" Margin="8,0,0,0"
                       Text="Must match the DataSource Name in your .rdx file."/>
        </Grid>

        <!-- Field grid -->
        <DataGrid x:Name="FieldGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  Background="#13131f"
                  RowBackground="#13131f"
                  AlternatingRowBackground="#1a1a2e"
                  BorderBrush="#3d3d5c"
                  BorderThickness="1"
                  HorizontalGridLinesBrush="#2a2a3e"
                  SelectionChanged="FieldGrid_SelectionChanged">

            <DataGrid.Columns>

                <DataGridTemplateColumn Header="Field Name" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Padding="4,2"
                                       Foreground="#e0e0f0" FontSize="12"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Data Type" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DataType}" Padding="4,2"
                                       Foreground="#e0e0f0" FontSize="12"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox SelectedItem="{Binding DataType}"
                                      ItemsSource="{Binding DataTypes,
                                          RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Caption" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Caption}" Padding="4,2"
                                       Foreground="#abb2bf" FontSize="12"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Caption, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Nullable" Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Nullable}" HorizontalAlignment="Center"
                                      IsEnabled="False"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Nullable}" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Sample Value" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SampleValue}" Padding="4,2"
                                       Foreground="#6b7280" FontSize="11" FontStyle="Italic"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding SampleValue, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Field toolbar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,0" >
            <Button Content="+ Add Field"   Style="{StaticResource PrimaryBtn}"
                    Click="AddField_Click" Margin="0,0,6,0"/>
            <Button Content="↑ Move Up"     Style="{StaticResource DarkBtn}"
                    Click="MoveUp_Click"    Margin="0,0,6,0" x:Name="MoveUpBtn"/>
            <Button Content="↓ Move Down"   Style="{StaticResource DarkBtn}"
                    Click="MoveDown_Click"  Margin="0,0,6,0" x:Name="MoveDownBtn"/>
            <Button Content="🗑 Remove"      Style="{StaticResource DangerBtn}"
                    Click="RemoveField_Click" Margin="0,0,6,0" x:Name="RemoveBtn"/>
            <Separator Width="1" Margin="4,0" Background="#3d3d5c"/>
            <Button Content="Import from SQL…" Style="{StaticResource DarkBtn}"
                    Click="ImportSql_Click" Margin="0,0,6,0"
                    ToolTip="Paste a CREATE TABLE or SELECT statement to auto-populate fields"/>
            <Button Content="Import from CSV…" Style="{StaticResource DarkBtn}"
                    Click="ImportCsv_Click"
                    ToolTip="Read column headers from a CSV file"/>
        </StackPanel>

        <!-- Sample data rows count hint -->
        <Border Grid.Row="4" Background="#2a2a3e" BorderBrush="#3d3d5c"
                BorderThickness="1" CornerRadius="4" Margin="0,10,0,0" Padding="8,6">
            <StackPanel>
                <TextBlock Foreground="#abb2bf" FontSize="11" Margin="0,0,0,4">
                    <Run FontWeight="Bold">Sample data</Run>
                    <Run> – add representative rows for design-time preview. These are embedded in the .rds file and never used at runtime.</Run>
                </TextBlock>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Sample rows:" VerticalAlignment="Center"
                               Foreground="#abb2bf" FontSize="11" Margin="0,0,8,0"/>
                    <TextBlock x:Name="SampleRowCountLabel" VerticalAlignment="Center"
                               Foreground="#e5c07b" FontSize="11" FontWeight="Bold"/>
                    <Button Content="Edit sample data…" Style="{StaticResource DarkBtn}"
                            Margin="12,0,0,0" FontSize="11" Padding="8,2"
                            Click="EditSampleData_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- OK / Cancel -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel" Style="{StaticResource DarkBtn}"
                    IsCancel="True" Margin="0,0,8,0" Width="80"/>
            <Button Content="Save Schema" Style="{StaticResource PrimaryBtn}"
                    IsDefault="True" Click="Save_Click" Width="110"/>
        </StackPanel>
    </Grid>
</Window>
