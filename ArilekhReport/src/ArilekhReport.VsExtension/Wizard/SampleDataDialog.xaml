<Window x:Class="ReportDesigner.VsExtension.Wizard.SampleDataDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Sample Data"
        Width="700" Height="420"
        MinWidth="500" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e2e" Foreground="#abb2bf">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="0,0,0,8" FontSize="13" FontWeight="Bold"
                   Foreground="#e0e0f0"
                   Text="Sample Data Rows"/>

        <!-- Dynamic DataGrid built in code-behind -->
        <DataGrid x:Name="SampleGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  Background="#13131f"
                  RowBackground="#13131f"
                  AlternatingRowBackground="#1a1a2e"
                  BorderBrush="#3d3d5c"
                  BorderThickness="1"
                  HorizontalGridLinesBrush="#2a2a3e"
                  Foreground="#e0e0f0"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
            <Button Content="+ Add Row"    Padding="10,4" Margin="0,0,6,0"
                    Background="#5b8ef0" Foreground="White" BorderThickness="0"
                    Click="AddRow_Click"/>
            <Button Content="🗑 Remove Row" Padding="10,4"
                    Background="#313148" Foreground="#e06c75"
                    BorderBrush="#e06c75" BorderThickness="1"
                    Click="RemoveRow_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel"  IsCancel="True"  Width="80" Padding="10,4"
                    Margin="0,0,8,0"  Background="#313148" Foreground="#abb2bf"
                    BorderBrush="#3d3d5c" BorderThickness="1"/>
            <Button Content="OK"      IsDefault="True" Width="80" Padding="10,4"
                    Background="#5b8ef0" Foreground="White" BorderThickness="0"
                    Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
