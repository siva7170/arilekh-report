@using ArilekhReport.Core.Rendering
@using ArilekhReport.Core.Model

@* Renders one RenderedPage as absolute-positioned divs/SVGs, identical to HtmlExporter
   but as live Blazor markup so the viewer can render pages individually. *@

<div class="rv-page"
     style="width:@(WidthPx)px;height:@(HeightPx)px;position:relative;background:white;overflow:hidden;"
     id="rv-page-@Page.PageNumber">

    @foreach (var el in Page.Elements)
    {
        @switch (el)
        {
            case RenderedTextElement txt:
                <div style="@TextStyle(txt)">@txt.Text</div>
                break;

            case RenderedRectElement rect:
                <div style="@RectStyle(rect)"></div>
                break;

            case RenderedLineElement line:
                <svg style="@LineSvgStyle(line)" xmlns="http://www.w3.org/2000/svg">
                    <line x1="@(X1(line))" y1="@(Y1(line))"
                          x2="@(X2(line))" y2="@(Y2(line))"
                          stroke="@line.StrokeColor"
                          stroke-width="@((line.StrokeWidth * Scale).ToString("F1"))" />
                </svg>
                break;

            case RenderedEllipseElement ell:
            {
                float w = ell.Width  * Scale;
                float h = ell.Height * Scale;
                float sw = ell.StrokeWidth * Scale;
                <svg style="position:absolute;left:@((ell.X*Scale).ToString("F1"))px;top:@((ell.Y*Scale).ToString("F1"))px;width:@(w.ToString("F1"))px;height:@(h.ToString("F1"))px;overflow:visible;@RotStyle(ell)"
                     xmlns="http://www.w3.org/2000/svg">
                    <ellipse cx="@((w/2).ToString("F1"))" cy="@((h/2).ToString("F1"))"
                             rx="@(Math.Max(0,w/2-sw/2).ToString("F1"))" ry="@(Math.Max(0,h/2-sw/2).ToString("F1"))"
                             fill="@(ell.FillColor ?? "none")"
                             stroke="@(ell.StrokeColor ?? "#000")"
                             stroke-width="@(sw.ToString("F1"))" />
                </svg>
                break;
            }

            case RenderedImageElement img:
                <img style="position:absolute;left:@((img.X*Scale).ToString("F1"))px;top:@((img.Y*Scale).ToString("F1"))px;width:@((img.Width*Scale).ToString("F1"))px;height:@((img.Height*Scale).ToString("F1"))px;object-fit:@img.Stretch;@RotStyle(img)"
                     src="@img.Src" alt="" />
                break;
        }
    }
</div>

@code {
    [Parameter, EditorRequired] public RenderedPage Page  { get; set; } = default!;
    [Parameter]                 public float        Scale { get; set; } = 1.333f;  // pt → px

    private float WidthPx  => Page.Width  * Scale;
    private float HeightPx => Page.Height * Scale;

    private string TextStyle(RenderedTextElement el)
    {
        var sb = new System.Text.StringBuilder();
        sb.Append($"position:absolute;left:{el.X*Scale:F1}px;top:{el.Y*Scale:F1}px;");
        sb.Append($"width:{el.Width*Scale:F1}px;height:{el.Height*Scale:F1}px;");
        sb.Append($"overflow:hidden;font-size:{(el.Style?.FontSize ?? 9f)*Scale:F1}px;");
        sb.Append($"color:{el.Style?.ForeColor ?? "#000"};");
        if (el.Style?.Bold    == true) sb.Append("font-weight:bold;");
        if (el.Style?.Italic  == true) sb.Append("font-style:italic;");
        if (el.Style?.BackColor is { } bg) sb.Append($"background:{bg};");
        sb.Append(el.Alignment switch
        {
            FieldAlignment.Center => "text-align:center;",
            FieldAlignment.Right  => "text-align:right;",
            _                     => "text-align:left;",
        });
        // Vertical align
        var va = el.VerticalAlign switch
        {
            FieldVerticalAlign.Middle => "center",
            FieldVerticalAlign.Bottom => "flex-end",
            _                         => "flex-start",
        };
        sb.Append($"display:flex;flex-direction:column;justify-content:{va};");
        if (el.Rotation != 0) sb.Append($"transform:rotate({el.Rotation:F1}deg);transform-origin:center center;");
        return sb.ToString();
    }

    private string RectStyle(RenderedRectElement el)
    {
        var sb = new System.Text.StringBuilder();
        sb.Append($"position:absolute;left:{el.X*Scale:F1}px;top:{el.Y*Scale:F1}px;");
        sb.Append($"width:{el.Width*Scale:F1}px;height:{el.Height*Scale:F1}px;");
        if (el.FillColor   is { } f) sb.Append($"background:{f};");
        if (el.StrokeColor is { } s) sb.Append($"border:{el.StrokeWidth*Scale:F1}px solid {s};");
        if (el.BorderRadius > 0)     sb.Append($"border-radius:{el.BorderRadius}%;");
        if (el.Rotation     != 0)    sb.Append($"transform:rotate({el.Rotation:F1}deg);transform-origin:center center;");
        return sb.ToString();
    }

    private string LineSvgStyle(RenderedLineElement el)
    {
        float left   = Math.Min(el.X,  el.X2) * Scale;
        float top    = Math.Min(el.Y,  el.Y2) * Scale;
        float width  = Math.Max(Math.Abs(el.X2 - el.X) * Scale, el.StrokeWidth * Scale + 2);
        float height = Math.Max(Math.Abs(el.Y2 - el.Y) * Scale, el.StrokeWidth * Scale + 2);
        var rot = el.Rotation != 0 ? $"transform:rotate({el.Rotation:F1}deg);transform-origin:center center;" : "";
        return $"position:absolute;left:{left:F1}px;top:{top:F1}px;width:{width:F1}px;height:{height:F1}px;overflow:visible;{rot}";
    }

    private string X1(RenderedLineElement el) => ((el.X  * Scale) - Math.Min(el.X, el.X2) * Scale).ToString("F1");
    private string Y1(RenderedLineElement el) => ((el.Y  * Scale) - Math.Min(el.Y, el.Y2) * Scale).ToString("F1");
    private string X2(RenderedLineElement el) => ((el.X2 * Scale) - Math.Min(el.X, el.X2) * Scale).ToString("F1");
    private string Y2(RenderedLineElement el) => ((el.Y2 * Scale) - Math.Min(el.Y, el.Y2) * Scale).ToString("F1");

    private static string RotStyle(RenderedElement el)
        => el.Rotation != 0 ? $"transform:rotate({el.Rotation:F1}deg);transform-origin:center center;" : "";
}
